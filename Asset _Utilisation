<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Geotab Asset Utilization Reporter - Zone-Based Analysis</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;background:linear-gradient(135deg,#2d5016 0%,#1a5f7a 50%,#57606f 100%);min-height:100vh;color:#333;padding:20px}
    .container{max-width:1400px;margin:0 auto}
    .header,.card{background:rgba(255,255,255,.95);backdrop-filter:blur(10px);border-radius:15px;padding:25px;margin-bottom:25px;box-shadow:0 10px 30px rgba(0,0,0,.1)}
    .header{text-align:center}
    .header h1{color:#2d3748;font-size:2.2em;font-weight:700;margin-bottom:10px}
    .card-title{color:#2d3748;font-size:1.3em;font-weight:700;margin-bottom:20px;padding-bottom:10px;border-bottom:2px solid #e2e8f0}
    .form-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:15px;margin-bottom:15px}
    .form-control,.form-select{width:100%;padding:12px 16px;border:2px solid #e2e8f0;border-radius:8px;font-size:14px;transition:all .2s ease}
    .form-control:focus,.form-select:focus{outline:none;border-color:#2d5016;box-shadow:0 0 0 3px rgba(45,80,22,.1)}
    .btn{padding:12px 24px;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s ease;margin:5px}
    .btn:hover{transform:translateY(-1px);box-shadow:0 4px 15px rgba(0,0,0,.2)}
    .btn-primary{background:linear-gradient(135deg,#2d5016,#1a5f7a);color:#fff}
    .btn-success{background:linear-gradient(135deg,#48bb78,#38a169);color:#fff}
    .btn-info{background:linear-gradient(135deg,#4299e1,#3182ce);color:#fff}
    .btn-warning{background:linear-gradient(135deg,#ed8936,#dd6b20);color:#fff}
    .btn-danger{background:linear-gradient(135deg,#f56565,#e53e3e);color:#fff}
    .btn[disabled]{opacity:.5;cursor:not-allowed}
    .alert{padding:15px;border-radius:8px;margin:15px 0;font-weight:500}
    .alert-success{background:#c6f6d5;color:#22543d;border-left:4px solid #38a169}
    .alert-error{background:#fed7d7;color:#742a2a;border-left:4px solid #e53e3e}
    .alert-warning{background:#fefcbf;color:#744210;border-left:4px solid #d69e2e}
    .alert-info{background:#ebf8ff;color:#2b6cb0;border-left:4px solid #4299e1}
    .utilization-table{width:100%;border-collapse:collapse;margin-top:20px;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 4px 15px rgba(0,0,0,.1)}
    .utilization-table th{background:linear-gradient(135deg,#2d5016,#1a5f7a);color:#fff;padding:12px;text-align:left;font-weight:600;font-size:13px}
    .utilization-table td{padding:10px 12px;border-bottom:1px solid #e2e8f0;font-size:13px;vertical-align:top}
    .utilization-table tr:hover{background:#f7fafc}
    .utilization-table tr:nth-child(even){background:#f8f9fa}
    .metric-high{background:#c6f6d5;color:#22543d;padding:4px 8px;border-radius:4px;font-weight:600}
    .metric-medium{background:#fefcbf;color:#744210;padding:4px 8px;border-radius:4px;font-weight:600}
    .metric-low{background:#fed7d7;color:#742a2a;padding:4px 8px;border-radius:4px;font-weight:600}
    .muted{color:#718096}
    .progress-bar{width:100%;background:#e2e8f0;border-radius:4px;overflow:hidden;margin:10px 0}
    .progress-fill{height:20px;background:linear-gradient(90deg,#2d5016,#1a5f7a);transition:width 0.3s ease;display:flex;align-items:center;justify-content:center;color:white;font-size:12px;font-weight:600}
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:15px;margin:20px 0}
    .stat-card{background:linear-gradient(135deg,#fff,#f8f9fa);border-radius:10px;padding:20px;text-align:center;border-left:4px solid #2d5016}
    .stat-number{font-size:2em;font-weight:700;color:#2d5016}
    .stat-label{color:#718096;margin-top:5px}
    .zone-pill{display:inline-block;background:#e2e8f0;border-radius:999px;padding:4px 12px;margin:2px;font-size:11px;color:#495057;font-weight:500}
    .zone-pill.active{background:#2d5016;color:#fff}
    .comparison-up{color:#28a745;font-weight:700}
    .comparison-down{color:#dc3545;font-weight:700}
    .comparison-same{color:#6c757d;font-weight:500}
    .emissions-high{background:#fed7d7;color:#742a2a;padding:4px 8px;border-radius:4px;font-weight:600}
    .emissions-medium{background:#fefcbf;color:#744210;padding:4px 8px;border-radius:4px;font-weight:600}
    .emissions-low{background:#c6f6d5;color:#22543d;padding:4px 8px;border-radius:4px;font-weight:600}
    .weekly-header{background:#f8f9fa;padding:10px;border-radius:6px;margin:10px 0;border-left:4px solid #2d5016}
    .period-label{font-size:11px;color:#666;display:block;margin-top:2px}
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>🚛 Geotab Asset Utilization Reporter</h1>
      <p>Comprehensive zone-based asset utilization analysis and reporting</p>
    </div>

    <div class="card">
      <h3 class="card-title">🔐 Authentication</h3>
      <div class="form-row">
        <input id="server" class="form-control" placeholder="Server" value="my.geotab.com" />
        <input id="database" class="form-control" placeholder="Database" value="uccnz" />
      </div>
      <div class="form-row">
        <input id="username" class="form-control" placeholder="Username" value="francis@directt.co.nz" />
        <input id="password" class="form-control" type="password" placeholder="Password" value="@fr4nc1sWynn5" />
      </div>
      <button id="authButton" class="btn btn-primary">🔒 Authenticate</button>
      <div id="authResult"></div>
    </div>

    <div id="reportSection" class="card" style="display:none;">
      <h3 class="card-title">📊 Asset Utilization Analysis</h3>
      
      <div class="card">
        <h4>🏢 Zone Selection</h4>
        <div id="zoneLoader" style="display:none;">
          <div class="progress-bar">
            <div class="progress-fill" style="width:100%;">Loading Zones...</div>
          </div>
        </div>
        <div class="form-row">
          <select id="zoneSelect" class="form-select" style="display:none;">
            <option value="">Select a zone...</option>
          </select>
          <button id="loadZones" class="btn btn-info">🔍 Load Available Zones</button>
        </div>
        <div id="selectedZones"></div>
      </div>

      <div class="card">
        <h4>📅 Reporting Options</h4>
        <div class="form-row">
          <select id="reportType" class="form-select">
            <option value="custom">Custom Date Range</option>
            <option value="weekly">Week-over-Week Comparison</option>
          </select>
        </div>
        <div id="customDateInputs" class="form-row">
          <input id="fromDate" class="form-control" type="date" />
          <input id="toDate" class="form-control" type="date" />
          <input id="resultsLimit" class="form-control" placeholder="Asset Limit" value="50" />
        </div>
        <div id="weeklyInputs" class="form-row" style="display:none;">
          <input id="resultsLimitWeekly" class="form-control" placeholder="Asset Limit" value="50" />
          <div class="alert alert-info">📊 Compares last week vs. previous week automatically</div>
        </div>
      </div>
      
      <div>
        <button id="generateReport" class="btn btn-success" disabled>📊 Generate Utilization Report</button>
        <button id="generateWeeklyReport" class="btn btn-warning" disabled style="display:none;">📈 Generate Weekly Comparison</button>
        <button id="exportCsv" class="btn btn-info" disabled>📈 Export CSV</button>
        <button id="exportDetailedReport" class="btn btn-warning" disabled>📋 Detailed Report</button>
        <button id="logout" class="btn btn-danger">🚪 Logout</button>
      </div>

      <div id="reportBanner"></div>
      
      <div id="progressContainer" style="display:none;">
        <div class="progress-bar">
          <div id="progressBar" class="progress-fill" style="width:0%;">0%</div>
        </div>
        <div id="progressText" class="muted" style="text-align:center;margin-top:5px;"></div>
      </div>

      <div id="summaryStats" style="display:none;">
        <h4>📈 Summary Statistics</h4>
        <div class="stats-grid">
          <div class="stat-card">
            <div id="totalAssets" class="stat-number">0</div>
            <div class="stat-label">Total Assets</div>
          </div>
          <div class="stat-card">
            <div id="avgUtilization" class="stat-number">0%</div>
            <div class="stat-label">Average Utilization</div>
          </div>
          <div class="stat-card">
            <div id="totalDistance" class="stat-number">0 km</div>
            <div class="stat-label">Total Distance</div>
          </div>
          <div class="stat-card">
            <div id="totalEngineHours" class="stat-number">0 hrs</div>
            <div class="stat-label">Total Engine Hours</div>
          </div>
          <div class="stat-card">
            <div id="totalEmissions" class="stat-number">0 kg</div>
            <div class="stat-label">Total CO₂ Emissions</div>
          </div>
          <div class="stat-card">
            <div id="avgEmissionsPerKm" class="stat-number">0 g/km</div>
            <div class="stat-label">Avg CO₂ per km</div>
          </div>
        </div>
      </div>

      <div id="weeklyComparison" style="display:none;">
        <h4>📊 Week-over-Week Comparison</h4>
        <div class="weekly-header">
          <strong id="comparisonPeriods">Comparison Period</strong>
          <div class="stats-grid" style="margin-top:15px;">
            <div class="stat-card">
              <div id="utilizationChange" class="stat-number">0%</div>
              <div class="stat-label">Utilization Change</div>
            </div>
            <div class="stat-card">
              <div id="distanceChange" class="stat-number">0 km</div>
              <div class="stat-label">Distance Change</div>
            </div>
            <div class="stat-card">
              <div id="emissionsChange" class="stat-number">0 kg</div>
              <div class="stat-label">Emissions Change</div>
            </div>
          </div>
        </div>
      </div>
      
      <div id="utilizationResult"></div>
    </div>
  </div>

<script>
let credentials = null;
let serverUsed = null;
let utilizationData = [];
let selectedZoneIds = new Set();
let availableZones = [];

function setDefaultDates(){
  const today = new Date();
  const lastMonth = new Date(today.getTime() - 30*24*60*60*1000);
  document.getElementById('toDate').value = today.toISOString().split('T')[0];
  document.getElementById('fromDate').value = lastMonth.toISOString().split('T')[0];
}
setDefaultDates();

function showMessage(elId, msg, type='info'){
  const el = document.getElementById(elId);
  const c = type==='error'?'alert-error':type==='success'?'alert-success':type==='warning'?'alert-warning':'alert-info';
  el.style.display = '';
  el.innerHTML = `<div class="alert ${c}">${msg}</div>`;
}

function updateProgress(current, total, text = '') {
  const container = document.getElementById('progressContainer');
  const bar = document.getElementById('progressBar');
  const textEl = document.getElementById('progressText');
  
  if (total === 0) {
    container.style.display = 'none';
    return;
  }
  
  container.style.display = 'block';
  const percentage = Math.round((current / total) * 100);
  bar.style.width = `${percentage}%`;
  bar.textContent = `${percentage}%`;
  textEl.textContent = text || `Processing ${current} of ${total}...`;
}

async function callGeotabAPI(method, params={}){
  if (window.geotab && typeof window.geotab.call === 'function'){
    return new Promise((resolve,reject)=>window.geotab.call(method, params, resolve, reject));
  }
  if (window.api && typeof window.api.call === 'function'){
    return new Promise((resolve,reject)=>window.api.call(method, params, resolve, reject));
  }
  const requestBody = { method, params: credentials ? {...params, credentials} : params };
  const res = await fetch(`https://${serverUsed}/apiv1`, {
    method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'}, body: JSON.stringify(requestBody)
  });
  if(!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
  const data = await res.json();
  if(data.error) throw new Error(data.error.message || data.error.name);
  return data.result;
}

function extractId(data){
  if(!data) return null;
  if(typeof data==='object' && data.id) return data.id;
  if(typeof data==='string'){ try{ return JSON.parse(data).id || null }catch(e){ return data } }
  return null;
}

function calculateUtilization(engineHours, totalHours) {
  if (!totalHours || totalHours === 0) return 0;
  return Math.min(100, Math.round((engineHours / totalHours) * 100 * 100) / 100);
}

function getUtilizationClass(utilization) {
  if (utilization >= 70) return 'metric-high';
  if (utilization >= 40) return 'metric-medium';
  return 'metric-low';
}

// Authentication
document.getElementById('authButton').onclick = async function(){
  const server = document.getElementById('server').value.trim();
  const database = document.getElementById('database').value.trim();
  const username = document.getElementById('username').value.trim();
  const password = document.getElementById('password').value;
  if(!server || !database || !username || !password){ showMessage('authResult','Please fill in all fields','error'); return; }
  try{
    showMessage('authResult','Authenticating...','warning');
    serverUsed = server;
    const res = await callGeotabAPI('Authenticate', { userName:username, password, database });
    if(res.path && res.path !== 'ThisServer'){
      serverUsed = res.path;
      const res2 = await callGeotabAPI('Authenticate', { userName:username, password, database });
      credentials = res2.credentials;
    } else {
      credentials = res.credentials;
    }
    showMessage('authResult','Authentication successful! 🎉','success');
    document.getElementById('reportSection').style.display = '';
  }catch(e){
    showMessage('authResult',`Authentication failed: ${e.message}`,'error');
  }
};

// Load available zones
document.getElementById('loadZones').onclick = async function(){
  if(!credentials && !window.geotab && !window.api){ showMessage('reportBanner','Not authenticated','error'); return; }
  
  try {
    document.getElementById('zoneLoader').style.display = 'block';
    showMessage('reportBanner', 'Loading zones...', 'info');
    
    const zones = await callGeotabAPI('Get', {
      typeName: 'Zone',
      resultsLimit: 1000
    });
    
    availableZones = zones.filter(z => z.name && z.name.trim());
    
    const zoneSelect = document.getElementById('zoneSelect');
    zoneSelect.innerHTML = '<option value="">Select a zone...</option>';
    
    availableZones.forEach(zone => {
      const option = document.createElement('option');
      option.value = zone.id;
      option.textContent = `${zone.name} (${zone.zoneTypes && zone.zoneTypes.length ? zone.zoneTypes.map(zt => zt.name || zt).join(', ') : 'Zone'})`;
      zoneSelect.appendChild(option);
    });
    
    document.getElementById('zoneLoader').style.display = 'none';
    zoneSelect.style.display = 'block';
    showMessage('reportBanner', `✅ Loaded ${availableZones.length} zones`, 'success');
    
  } catch (error) {
    document.getElementById('zoneLoader').style.display = 'none';
    showMessage('reportBanner', `Failed to load zones: ${error.message}`, 'error');
  }
};

// Zone selection handling
document.getElementById('zoneSelect').onchange = function() {
  const select = this;
  const selectedId = select.value;
  const selectedText = select.options[select.selectedIndex].text;
  
  if (selectedId && !selectedZoneIds.has(selectedId)) {
    selectedZoneIds.add(selectedId);
    updateSelectedZonesDisplay();
    document.getElementById('generateReport').disabled = selectedZoneIds.size === 0;
  }
  
  select.value = ''; // Reset selection
};

function updateSelectedZonesDisplay() {
  const container = document.getElementById('selectedZones');
  const zones = Array.from(selectedZoneIds).map(id => {
    const zone = availableZones.find(z => z.id === id);
    return zone ? { id, name: zone.name } : null;
  }).filter(Boolean);
  
  container.innerHTML = zones.map(zone => 
    `<span class="zone-pill active">${zone.name} <span onclick="removeZone('${zone.id}')" style="cursor:pointer;margin-left:5px;">×</span></span>`
  ).join('');
}

function removeZone(zoneId) {
  selectedZoneIds.delete(zoneId);
  updateSelectedZonesDisplay();
  document.getElementById('generateReport').disabled = selectedZoneIds.size === 0;
}

// Generate utilization report
document.getElementById('generateReport').onclick = async function(){
  if(!credentials && !window.geotab && !window.api){ showMessage('reportBanner','Not authenticated','error'); return; }
  if(selectedZoneIds.size === 0){ showMessage('reportBanner','Please select at least one zone','error'); return; }
  
  const fromDate = document.getElementById('fromDate').value;
  const toDate = document.getElementById('toDate').value;
  const resultsLimit = parseInt(document.getElementById('resultsLimit').value) || 50;
  if(!fromDate || !toDate){ showMessage('reportBanner','Please select both from and to dates','error'); return; }

  try {
    showMessage('reportBanner','🔄 Generating comprehensive utilization report...','info');
    document.getElementById('exportCsv').disabled = true;
    document.getElementById('exportDetailedReport').disabled = true;
    
    const fromDateTime = fromDate + 'T00:00:00.000Z';
    const toDateTime = toDate + 'T23:59:59.000Z';
    const totalHours = (new Date(toDateTime) - new Date(fromDateTime)) / (1000 * 60 * 60);
    
    updateProgress(1, 6, 'Getting devices...');
    
    // Get all devices
    const devices = await callGeotabAPI('Get', {
      typeName: 'Device',
      resultsLimit: resultsLimit
    });
    
    if (!devices.length) {
      showMessage('reportBanner', 'No devices found', 'warning');
      return;
    }
    
    updateProgress(2, 6, 'Getting status data...');
    
    // Get device status data for the date range
    const statusData = await callGeotabAPI('Get', {
      typeName: 'StatusData',
      search: {
        fromDate: fromDateTime,
        toDate: toDateTime,
        diagnosticSearch: { id: 'DiagnosticEngineHoursId' }
      },
      resultsLimit: 5000
    });
    
    updateProgress(3, 6, 'Getting trip data...');
    
    // Get trip data
    const trips = await callGeotabAPI('Get', {
      typeName: 'Trip',
      search: {
        fromDate: fromDateTime,
        toDate: toDateTime
      },
      resultsLimit: 5000
    });
    
    updateProgress(4, 6, 'Getting zone stops...');
    
    // Get zone stops for selected zones
    const zoneStops = [];
    for (const zoneId of selectedZoneIds) {
      try {
        const stops = await callGeotabAPI('Get', {
          typeName: 'ZoneStop',
          search: {
            fromDate: fromDateTime,
            toDate: toDateTime,
            zoneSearch: { id: zoneId }
          },
          resultsLimit: 1000
        });
        zoneStops.push(...stops);
      } catch (e) {
        console.warn(`Failed to get zone stops for zone ${zoneId}:`, e);
      }
    }
    
    updateProgress(5, 6, 'Processing utilization data...');
    
    // Process utilization data
    utilizationData = devices.map(device => {
      const deviceId = device.id;
      const deviceName = device.name || `Device ${deviceId}`;
      
      // Get engine hours for this device
      const deviceStatusData = statusData.filter(s => extractId(s.device) === deviceId);
      const engineHours = deviceStatusData.length > 0 ? 
        Math.max(...deviceStatusData.map(s => s.data || 0)) / 3600 : 0;
      
      // Get trips for this device
      const deviceTrips = trips.filter(t => extractId(t.device) === deviceId);
      const totalDistance = deviceTrips.reduce((sum, trip) => sum + (trip.distance || 0), 0) / 1000; // Convert to km
      const tripCount = deviceTrips.length;
      
      // Get zone stops for this device
      const deviceZoneStops = zoneStops.filter(s => extractId(s.device) === deviceId);
      const zoneTimeHours = deviceZoneStops.reduce((sum, stop) => {
        const duration = stop.duration || 0;
        return sum + (duration / 3600); // Convert seconds to hours
      }, 0);
      
      const utilization = calculateUtilization(engineHours, totalHours);
      
      return {
        deviceId,
        deviceName,
        engineHours: Math.round(engineHours * 100) / 100,
        totalDistance: Math.round(totalDistance * 100) / 100,
        tripCount,
        zoneTimeHours: Math.round(zoneTimeHours * 100) / 100,
        zoneStops: deviceZoneStops.length,
        utilization,
        utilizationClass: getUtilizationClass(utilization),
        lastActivity: deviceTrips.length > 0 ? 
          new Date(Math.max(...deviceTrips.map(t => new Date(t.stop || t.start)))).toLocaleDateString() : 
          'No activity'
      };
    }).filter(d => d.engineHours > 0 || d.tripCount > 0 || d.zoneStops > 0)
      .sort((a, b) => b.utilization - a.utilization);
    
    updateProgress(6, 6, 'Complete!');
    
    // Update summary statistics
    updateSummaryStats();
    
    // Render the utilization table
    renderUtilizationTable();
    
    const activeAssets = utilizationData.length;
    const avgUtil = utilizationData.length > 0 ? 
      Math.round(utilizationData.reduce((sum, d) => sum + d.utilization, 0) / utilizationData.length) : 0;
    
    showMessage('reportBanner', 
      `✅ Report generated! Found ${activeAssets} active assets with ${avgUtil}% average utilization`, 
      'success');
    
    document.getElementById('exportCsv').disabled = false;
    document.getElementById('exportDetailedReport').disabled = false;
    
  } catch (error) {
    showMessage('reportBanner', `Failed to generate report: ${error.message}`, 'error');
  }
};

function updateSummaryStats() {
  const totalAssets = utilizationData.length;
  const avgUtilization = totalAssets > 0 ? 
    Math.round(utilizationData.reduce((sum, d) => sum + d.utilization, 0) / totalAssets) : 0;
  const totalDistance = Math.round(utilizationData.reduce((sum, d) => sum + d.totalDistance, 0));
  const totalEngineHours = Math.round(utilizationData.reduce((sum, d) => sum + d.engineHours, 0));
  
  document.getElementById('totalAssets').textContent = totalAssets;
  document.getElementById('avgUtilization').textContent = avgUtilization + '%';
  document.getElementById('totalDistance').textContent = totalDistance.toLocaleString() + ' km';
  document.getElementById('totalEngineHours').textContent = totalEngineHours.toLocaleString() + ' hrs';
  
  document.getElementById('summaryStats').style.display = 'block';
}

function renderUtilizationTable() {
  const resultDiv = document.getElementById('utilizationResult');
  
  let html = `<table class="utilization-table"><thead><tr>
    <th>Asset Name</th>
    <th>Utilization %</th>
    <th>Engine Hours</th>
    <th>Distance (km)</th>
    <th>Trip Count</th>
    <th>Zone Time (hrs)</th>
    <th>Zone Stops</th>
    <th>Last Activity</th>
  </tr></thead><tbody>`;
  
  utilizationData.forEach(asset => {
    html += `<tr>
      <td><strong>${asset.deviceName}</strong></td>
      <td><span class="${asset.utilizationClass}">${asset.utilization}%</span></td>
      <td>${asset.engineHours}</td>
      <td>${asset.totalDistance.toLocaleString()}</td>
      <td>${asset.tripCount}</td>
      <td>${asset.zoneTimeHours}</td>
      <td>${asset.zoneStops}</td>
      <td class="muted">${asset.lastActivity}</td>
    </tr>`;
  });
  
  html += `</tbody></table>`;
  resultDiv.innerHTML = html;
}

// Export CSV
document.getElementById('exportCsv').onclick = function(){
  if(!utilizationData || utilizationData.length===0){ showMessage('reportBanner','No utilization data to export','warning'); return; }
  
  const headers = ['Asset_Name','Asset_ID','Utilization_Percent','Engine_Hours','Distance_KM','Trip_Count','Zone_Time_Hours','Zone_Stops','Last_Activity'];
  let csv = headers.join(',') + '\n';
  
  utilizationData.forEach(asset => {
    const row = [
      `"${asset.deviceName}"`,
      `"${asset.deviceId}"`,
      asset.utilization,
      asset.engineHours,
      asset.totalDistance,
      asset.tripCount,
      asset.zoneTimeHours,
      asset.zoneStops,
      `"${asset.lastActivity}"`
    ].join(',');
    csv += row + '\n';
  });
  
  const ts = new Date().toISOString().slice(0,19).replace(/[:.]/g,'-');
  const filename = `Asset_Utilization_Report_${ts}.csv`;
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a');
  const url = URL.createObjectURL(blob);
  a.href = url; a.download = filename; a.style.display='none';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  showMessage('reportBanner', `📊 CSV "${filename}" downloaded`, 'success');
};

// Export detailed report
document.getElementById('exportDetailedReport').onclick = function(){
  if(!utilizationData || utilizationData.length===0){ showMessage('reportBanner','No utilization data to export','warning'); return; }
  
  const selectedZoneNames = Array.from(selectedZoneIds).map(id => {
    const zone = availableZones.find(z => z.id === id);
    return zone ? zone.name : id;
  });
  
  const totalAssets = utilizationData.length;
  const avgUtilization = Math.round(utilizationData.reduce((sum, d) => sum + d.utilization, 0) / totalAssets);
  const totalDistance = Math.round(utilizationData.reduce((sum, d) => sum + d.totalDistance, 0));
  const totalEngineHours = Math.round(utilizationData.reduce((sum, d) => sum + d.engineHours, 0));
  
  const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Asset Utilization Report</title>
  <style>
    body{font-family:Arial,sans-serif;margin:20px;color:#333}
    h1{color:#2d5016;margin:0 0 10px 0} 
    .meta{color:#666;margin-bottom:20px}
    .summary{background:#f8f9fa;padding:15px;border-radius:8px;margin:20px 0}
    .summary h3{margin:0 0 10px 0;color:#2d5016}
    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin:20px 0}
    .stat{text-align:center;padding:15px;background:#fff;border-radius:8px;border-left:4px solid #2d5016}
    .stat-number{font-size:2em;font-weight:700;color:#2d5016}
    .stat-label{color:#666;font-size:0.9em}
    table{width:100%;border-collapse:collapse;margin-top:16px}
    th,td{border:1px solid #ddd;padding:8px;font-size:12px;text-align:left}
    th{background:#2d5016;color:#fff}
    tr:nth-child(even){background:#f9f9f9}
    .util-high{background:#c6f6d5;color:#22543d;padding:2px 6px;border-radius:3px;font-weight:600}
    .util-medium{background:#fefcbf;color:#744210;padding:2px 6px;border-radius:3px;font-weight:600}
    .util-low{background:#fed7d7;color:#742a2a;padding:2px 6px;border-radius:3px;font-weight:600}
  </style></head><body>
  <h1>🚛 Asset Utilization Report</h1>
  <div class="meta">Generated: ${new Date().toLocaleString()}<br>
  Date Range: ${document.getElementById('fromDate').value} to ${document.getElementById('toDate').value}<br>
  Selected Zones: ${selectedZoneNames.join(', ')}</div>
  
  <div class="summary">
    <h3>📈 Executive Summary</h3>
    <div class="stats">
      <div class="stat"><div class="stat-number">${totalAssets}</div><div class="stat-label">Total Assets</div></div>
      <div class="stat"><div class="stat-number">${avgUtilization}%</div><div class="stat-label">Average Utilization</div></div>
      <div class="stat"><div class="stat-number">${totalDistance.toLocaleString()}</div><div class="stat-label">Total Distance (km)</div></div>
      <div class="stat"><div class="stat-number">${totalEngineHours.toLocaleString()}</div><div class="stat-label">Total Engine Hours</div></div>
    </div>
  </div>
  
  <table><thead><tr>
    <th>Asset Name</th><th>Utilization</th><th>Engine Hours</th><th>Distance (km)</th><th>Trips</th><th>Zone Time (hrs)</th><th>Zone Stops</th><th>Last Activity</th>
  </tr></thead><tbody>
  ${utilizationData.map(asset => `<tr>
    <td><strong>${asset.deviceName}</strong></td>
    <td><span class="util-${asset.utilization >= 70 ? 'high' : asset.utilization >= 40 ? 'medium' : 'low'}">${asset.utilization}%</span></td>
    <td>${asset.engineHours}</td>
    <td>${asset.totalDistance.toLocaleString()}</td>
    <td>${asset.tripCount}</td>
    <td>${asset.zoneTimeHours}</td>
    <td>${asset.zoneStops}</td>
    <td>${asset.lastActivity}</td>
  </tr>`).join('')}
  </tbody></table>
  </body></html>`;
  
  const ts = new Date().toISOString().slice(0,19).replace(/[:.]/g,'-');
  const filename = `Detailed_Asset_Utilization_Report_${ts}.html`;
  const blob = new Blob([html], {type:'text/html;charset=utf-8;'});
  const a = document.createElement('a');
  const url = URL.createObjectURL(blob);
  a.href = url; a.download = filename; a.style.display='none';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  showMessage('reportBanner', `📋 Detailed report "${filename}" downloaded`, 'success');
};

// Logout
document.getElementById('logout').onclick = function(){
  credentials = null; 
  serverUsed = null; 
  utilizationData = [];
  selectedZoneIds.clear();
  document.getElementById('reportSection').style.display = 'none';
  document.getElementById('authResult').innerHTML = '';
  document.getElementById('utilizationResult').innerHTML = '';
  document.getElementById('summaryStats').style.display = 'none';
  showMessage('reportBanner','Logged out','info');
};

// Auto-show report section if running in Geotab environment
if (window.geotab || window.api || (window.location && /geotab\.com/i.test(window.location.host))) {
  document.getElementById('reportSection').style.display='';
}
</script>
