<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="64" height="64">
  <!-- Background circle -->
  <circle cx="32" cy="32" r="30" fill="#667eea" stroke="#4c51bf" stroke-width="2"/>
  
  <!-- Truck body -->
  <rect x="12" y="22" width="28" height="16" rx="2" fill="#ffffff"/>
  
  <!-- Truck cabin -->
  <rect x="12" y="18" width="12" height="8" rx="1" fill="#ffffff"/>
  
  <!-- Front grille -->
  <rect x="12" y="20" width="2" height="4" fill="#e2e8f0"/>
  
  <!-- Truck wheels -->
  <circle cx="18" cy="42" r="4" fill="#4a5568"/>
  <circle cx="18" cy="42" r="2" fill="#2d3748"/>
  <circle cx="34" cy="42" r="4" fill="#4a5568"/>
  <circle cx="34" cy="42" r="2" fill="#2d3748"/>
  
  <!-- Truck cargo area details -->
  <rect x="26" y="24" width="12" height="2" fill="#e2e8f0"/>
  <rect x="26" y="28" width="12" height="2" fill="#e2e8f0"/>
  <rect x="26" y="32" width="12" height="2" fill="#e2e8f0"/>
  
  <!-- Distance/measurement icon -->
  <text x="44" y="24" font-family="Arial, sans-serif" font-size="8" font-weight="bold" fill="#48bb78">KM</text>
  
  <!-- Road lines -->
  <rect x="8" y="46" width="48" height="2" fill="#f7fafc"/>
  <rect x="10" y="48" width="4" height="1" fill="#e2e8f0"/>
  <rect x="18" y="48" width="4" height="1" fill="#e2e8f0"/>
  <rect x="26" y="48" width="4" height="1" fill="#e2e8f0"/>
  <rect x="34" y="48" width="4" height="1" fill="#e2e8f0"/>
  <rect x="42" y="48" width="4" height="1" fill="#e2e8f0"/>
  <rect x="50" y="48" width="4" height="1" fill="#e2e8f0"/>
</svg>
